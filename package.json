{
  "name": "bizzy-enrichment",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:server": "bun run --hot src/main.ts",
    "dev:web": "vite",
    "dev": "bun run dev:server & bun run dev:web",
    "build": "NODE_ENV=production vite build",
    "start": "bun run src/main.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "bun run lint && bun run typecheck && bun run test",
    "eval": "bun run eval/run.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "vite": "^8.0.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@hono/zod-validator": "^0.7.6",
    "cheerio": "^1.2.0",
    "hono": "^4.12.15",
    "hono-rate-limiter": "^0.5.3",
    "i18next": "^26.0.8",
    "ipaddr.js": "^2.3.0",
    "metascraper": "^5.50.1",
    "metascraper-publisher": "^5.50.1",
    "metascraper-title": "^5.50.1",
    "normalize-url": "^9.0.0",
    "pino": "^10.3.1",
    "react-i18next": "^17.0.4",
    "rss-parser": "^3.13.0",
    "tldts": "^7.0.28",
    "zod": "^4.3.6"
  }
}
